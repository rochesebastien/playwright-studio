{
  "name": "playwright-studio",
  "version": "0.1.0",
  "description": "Launcher desktop lançant un Chromium Playwright isolé et déléguant le recording à Playwright codegen.",
  "author": "Playwright Studio",
  "license": "UNLICENSED",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "prepare-browsers": "node scripts/prepare-browsers.mjs",
    "dist:win": "electron-vite build && electron-builder --win --x64"
  },
  "dependencies": {
    "playwright": "1.56.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "electron": "38.8.6",
    "electron-builder": "^26",
    "electron-vite": "^4",
    "react": "^18",
    "react-dom": "^18",
    "typescript": "^5",
    "vite": "^7",
    "vitest": "^3"
  }
}
